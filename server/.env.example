# ─────────────────────────────────────────────
#  Rupkala Server – Environment Variables
#  Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

PORT=5000
NODE_ENV=development

# MongoDB – replace with your Atlas URI or local string
MONGO_URI=mongodb://localhost:27017/rupkala

# JWT – use a long random secret in production
JWT_SECRET=rupkala_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# Razorpay dummy keys (for simulation only)
RAZORPAY_KEY_ID=rzp_test_dummy_key
RAZORPAY_KEY_SECRET=dummy_secret
